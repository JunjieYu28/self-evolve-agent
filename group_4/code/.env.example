# ---------- LLM 后端 ----------
# eas = PAI-EAS 云端；sglang / vllm = 本地 OpenAI 兼容（先运行 scripts/start_vllm.sh）
LLM_BACKEND=vllm

# 本地 vLLM / SGLang（LLM_BACKEND=sglang 或 vllm 时使用）
LLM_BASE_URL=http://127.0.0.1:8001/v1
LLM_API_KEY=EMPTY
MODEL_NAME=qwen-3.5
MAX_TOKENS=4096
LLM_TEMPERATURE=1.0
LLM_ENABLE_THINKING=true

# 反思 / 记忆辅助模型（课题推荐 Qwen3-32B，不得作为 Harness 基座）
REFLECTION_LLM_BASE_URL=http://127.0.0.1:8000/v1
REFLECTION_MODEL_NAME=Qwen3-32B
REFLECTION_LLM_API_KEY=EMPTY
REFLECTION_MAX_TOKENS=2048
REFLECTION_TEMPERATURE=0.3
REFLECTION_ENABLE_THINKING=false
REFLECTION_LLM_TIMEOUT=300

# PAI-EAS（LLM_BACKEND=eas 时使用）
EAS_API_URL=http://gw-bzokqkvr2cblz8ok6y.cn-wulanchabu-acdr-1.pai-eas.aliyuncs.com/api/predict/qwen_35_9b
EAS_API_TOKEN=your_token_here
EAS_MODEL_NAME=qwen_35_9b
EAS_TEMPERATURE=0.7
EAS_MAX_TOKENS=2048
EAS_TIMEOUT=120
EAS_ENABLE_THINKING=false

# ---------- 本机一站式（不用启智）----------
# 启动: source /data/jcy/set_proxy.sh && bash scripts/start_all_local.sh
# 另开: CUDA_VISIBLE_DEVICES=0 bash scripts/start_vllm.sh

# ---------- 搜索 search-proxy（本机 8090）----------
SEARCH_PROXY_URL=http://127.0.0.1:8090
SEARCH_PROXY_TOKEN=
SEARCH_PROXY_TIMEOUT=120
SEARCH_PROXY_VERIFY_SSL=true

# 直连兜底（未启动 search-proxy 时）
SERPER_API_KEY=your_serper_key_here
JINA_API_KEY=your_jina_key_here

# Hugging Face 缓存目录（根分区满时请放到 /data）
HF_HOME=/data/jcy/huggingface_cache
HF_HUB_CACHE=/data/jcy/huggingface_cache/hub
TRANSFORMERS_CACHE=/data/jcy/huggingface_cache/hub

# 文搜 Cross-Encoder 重排（广度召回 SEARCH_FETCH_K 条后精排为 top_k）
# 本地 ModelScope 下载目录，或 HF id：BAAI/bge-reranker-v2-m3
SEARCH_RERANKER_MODEL=/data/jcy/ckpt/bge-reranker-v2-m3/AI-ModelScope/bge-reranker-v2-m3
SEARCH_RERANKER_ENABLED=true
SEARCH_FETCH_K=20

# ---------- 浏览器 browser-service（harness 默认 8080）----------
# 无 sudo 装 Chromium 依赖时: DISABLE_BROWSER=1（Agent 仅用 search_text/search_image）
DISABLE_BROWSER=0
SANDBOX_BASE_URL=http://127.0.0.1:8080
SANDBOX_API_TOKEN=
